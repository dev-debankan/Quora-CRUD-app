<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post Details</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9ff; }
        h1, h2, h3 { font-family: 'Manrope', sans-serif; }
    </style>
</head>
<body class="min-h-screen text-slate-800">
    <header class="sticky top-0 z-50 bg-white/70 backdrop-blur-lg border-b border-white/20 shadow-sm">
        <div class="max-w-2xl mx-auto px-4 py-4 flex items-center gap-4">
            <a href="/posts" class="text-slate-500 hover:text-slate-900 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            </a>
            <h1 class="text-xl font-bold">Post Details</h1>
        </div>
    </header>

    <main class="max-w-2xl mx-auto px-4 py-8">
        <div class="bg-white rounded-2xl p-6 md:p-10 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100">
            <div class="flex flex-col md:flex-row md:justify-between mb-8 pb-6 border-b border-slate-100 gap-4">
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-full bg-gradient-to-br from-indigo-100 to-indigo-200 flex items-center justify-center text-indigo-700 font-bold text-2xl">
                        <%= post.username.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                        <h3 class="font-bold text-xl text-slate-900">@<%= post.username %></h3>
                        <p class="text-sm border border-slate-200 bg-slate-50 rounded-md px-2 py-0.5 inline-block text-slate-500 mt-1 font-mono">ID: <%= post.id %></p>
                    </div>
                </div>
                <!-- Actions -->
                <div class="flex items-center gap-3 self-start md:self-center">
                     <a href="/posts/<%= post.id %>/edit" class="px-4 py-2 bg-indigo-50 text-indigo-600 hover:bg-indigo-100 font-medium rounded-lg transition-colors">Edit</a>
                     <form method="post" action="/posts/<%= post.id %>?_method=DELETE" class="m-0">
                        <button type="submit" class="px-4 py-2 bg-red-50 text-red-600 hover:bg-red-100 font-medium rounded-lg transition-colors">Delete</button>
                    </form>
                </div>
            </div>
            
            <div class="prose prose-slate max-w-none">
                <p class="text-slate-800 text-xl leading-relaxed whitespace-pre-wrap"><%= post.content %></p>
            </div>
        </div>
    </main>
</body>
</html>