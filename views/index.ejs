<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Posts</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9ff; }
        h1, h2, h3, h4, h5, h6 { font-family: 'Manrope', sans-serif; }
    </style>
</head>
<body class="min-h-screen text-slate-800 pb-24">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/70 backdrop-blur-lg border-b border-white/20 shadow-sm">
        <div class="max-w-3xl mx-auto px-4 py-5 flex justify-between items-center">
            <h1 class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-indigo-800 tracking-tight">AskForge</h1>
        </div>
    </header>

    <main class="max-w-2xl mx-auto px-4 py-8 space-y-6">
        <% if (posts.length === 0) { %>
            <div class="text-center py-12">
                <p class="text-slate-500">No posts yet. Be the first to share your thoughts!</p>
            </div>
        <% } %>
        
        <% for(post of posts) { %>
            <div class="bg-white rounded-2xl p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 transition-transform duration-300 hover:-translate-y-1">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-100 to-indigo-200 flex items-center justify-center text-indigo-700 font-bold text-lg">
                        <%= post.username.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                        <h3 class="font-semibold text-slate-900">@<%= post.username %></h3>
                    </div>
                </div>
                
                <p class="text-slate-600 text-lg leading-relaxed mb-6 whitespace-pre-wrap"><%= post.content %></p>
                
                <div class="flex items-center justify-between pt-4 border-t border-slate-50">
                    <div class="flex gap-4">
                        <a href="/posts/<%= post.id %>" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors">Details</a>
                        <a href="/posts/<%= post.id %>/edit" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors">Edit</a>
                    </div>
                    <form method="post" action="/posts/<%= post.id %>?_method=DELETE" class="m-0">
                        <button type="submit" class="text-sm font-medium text-red-400 hover:text-red-600 transition-colors">Delete</button>
                    </form>
                </div>
            </div>
        <% } %>
    </main>

    <!-- FAB -->
    <a href="/posts/new" class="fixed bottom-8 right-8 lg:bottom-12 lg:right-12 bg-gradient-to-r from-indigo-600 to-indigo-700 text-white p-4 rounded-full shadow-lg shadow-indigo-600/30 hover:shadow-indigo-600/50 hover:scale-105 transition-all duration-300 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
    </a>
</body>
</html>
